    "tailwindcss": "^3.4.4",
    "vue": "3.4.30",
    "vue-recaptcha-v3": "^2.0.1",
    "vue-router": "4.4.0",
    "vuex": "4.1.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.21.0",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "^5.0.8",
    "@vue/component-compiler-utils": "^3.3.0",
    "eslint-plugin-vue": "^9.26.0",
    "postcss": "^8.4.38",
