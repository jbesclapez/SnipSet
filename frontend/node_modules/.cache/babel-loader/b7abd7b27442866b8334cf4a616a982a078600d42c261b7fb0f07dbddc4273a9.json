{"ast":null,"code":"export default {\n  data() {\n    return {\n      email: '',\n      password: ''\n    };\n  },\n  methods: {\n    onSubmit() {\n      // Handle login logic here\n      alert(`Login attempt with ${this.email}`);\n    },\n    loginWith(service) {\n      // Trigger login with external service\n      alert(`Login with ${service}`);\n    }\n  }\n};","map":{"version":3,"names":["data","email","password","methods","onSubmit","alert","loginWith","service"],"sources":["C:\\Users\\nicol\\Nextcloud\\Documents\\GIT_Projects\\SnipSet\\frontend\\src\\components\\LoginForm.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-form\">\r\n    <img src=\"@/assets/logo.png\" alt=\"Logo\" class=\"logo\" />\r\n    \r\n    <form @submit.prevent=\"onSubmit\">\r\n      <div class=\"input-group\">\r\n        <input type=\"email\" v-model=\"email\" placeholder=\"Email address\" required />\r\n      </div>\r\n      <div class=\"input-group\">\r\n        <input type=\"password\" v-model=\"password\" placeholder=\"Password\" required />\r\n      </div>\r\n      <button type=\"submit\">Log In</button>\r\n    </form>\r\n\r\n    <div class=\"alternative-login\">\r\n      <button @click=\"loginWith('google')\">Continue with Google</button>\r\n      <button @click=\"loginWith('apple')\">Continue with Apple</button>\r\n      <button @click=\"loginWith('facebook')\">Continue with Facebook</button>\r\n    </div>\r\n\r\n    <a href=\"#\" class=\"forgot-password\">Can't log in?</a>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      email: '',\r\n      password: ''\r\n    };\r\n  },\r\n  methods: {\r\n    onSubmit() {\r\n      // Handle login logic here\r\n      alert(`Login attempt with ${this.email}`);\r\n    },\r\n    loginWith(service) {\r\n      // Trigger login with external service\r\n      alert(`Login with ${service}`);\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.login-form {\r\n  max-width: 400px;\r\n  margin: auto;\r\n  padding: 20px;\r\n  box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.input-group input {\r\n  width: 100%;\r\n  padding: 10px;\r\n  margin: 10px 0;\r\n  display: inline-block;\r\n  border: 1px solid #ccc;\r\n  box-sizing: border-box;\r\n}\r\n\r\nbutton {\r\n  background-color: #4CAF50;\r\n  color: white;\r\n  padding: 14px 20px;\r\n  margin: 8px 0;\r\n  border: none;\r\n  cursor: pointer;\r\n  width: 100%;\r\n}\r\n\r\nbutton:hover {\r\n  opacity: 0.8;\r\n}\r\n\r\n.alternative-login button {\r\n  background-color: #f1f1f1;\r\n  color: black;\r\n}\r\n\r\n.forgot-password {\r\n  display: block;\r\n  text-align: center;\r\n  margin-top: 12px;\r\n}\r\n\r\n.logo {\r\n  display: block;\r\n  margin: 10px auto;\r\n}\r\n</style>\r\n"],"mappings":"AAyBA,eAAe;EACbA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE;IACZ,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,QAAQA,CAAA,EAAG;MACT;MACAC,KAAK,CAAC,sBAAsB,IAAI,CAACJ,KAAK,EAAE,CAAC;IAC3C,CAAC;IACDK,SAASA,CAACC,OAAO,EAAE;MACjB;MACAF,KAAK,CAAC,cAAcE,OAAO,EAAE,CAAC;IAChC;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}